        "#tuple\n",
        "t=[10,20,30]\n",
        "print(t[0])\n",
        "print([-1])\n",
        "# example\n",
        "marks = [98,90,80,95]\n",
        "\n",
        "#list -> change\n",
        "# marks[3] = 50\n",
        "# print (type (marks))\n",
        "# print (marks)\n",
        "#tuple -> not change\n",
        "t = tuple (marks)\n",
        "print(type(t))\n",
        "print(t)\n",
        "\n",
        "#tuple-->list\n",
        "m = list(t)\n",
        "print(type(m))\n",
        "print(m)\n"
      ],
